# Railway Variables (or rename to .env locally). Do not commit real tokens.

PORT=5000
PLUXO_WEBHOOK_SECRET=change_me
AUTH_SECRET_KEY=

TELEGRAM_BOT_TOKEN=
OWNER_TELEGRAM_ID=
ADMIN_TELEGRAM_IDS=

DISABLE_TELEGRAM_BOT=
PLUXO_TELEGRAM_POLL=
PLUXO_SITE_OWNER_USERNAME=
SITE_ADMIN_USERNAMES=

STOCK_BATCH_MAX=5000
TELEGRAM_HTTP_TIMEOUT=45

# Default section header for stock document imports (BLACKJACK_BASE, MONEYJR_BASE, …)
# PLUXO_DOCUMENT_DEFAULT_BASE=BLACKJACK_BASE

# Optional: GOATYS Telegram folder invite (backend defaults if unset).
# GOATYS_TELEGRAM_CHAT_LIST_URL=

# Optional: mount a Railway Volume on /app/data so state.json survives redeploys.
# Web + Telegram must share the SAME state file (one volume / one PLUXO_STATE_PATH), or
# top-up Accept and /stock → site will not see each other's data.
# PLUXO_STATE_PATH=/app/data/state.json